  height:90px;\n        margin:0 auto;\n        border:2px solid #000000;\n        border-radius:50%;\n        line-height:90px;\n        font-size:42px;\n        font-weight:700;\n        color:#000000;\n        text-align:center;\n      \">\n        K\n      </div>\n    </div>\n\n  </div>\n\n  <div style=\"\n    border-top:1px solid #e5e5e5;\n    background:#fafafa;\n    padding:20px;\n    text-align:center;\n    color:#666666;\n    font-size:12px;\n    letter-spacing:1.5px;\n  \">\n    THANK YOU FOR YOUR INTEREST\n  </div>\n\n</div>\n`}}",
