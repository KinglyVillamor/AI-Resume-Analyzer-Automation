    {
      "parameters": {
        "jsCode": "// Get the AI analysis from the input\nconst item = $input.all()[0];\nconst aiOutput = item.json;\n\n// ⚠️ CRITICAL: Get preserved binary from Set node\n// The Set node still has the binary because it was never modified\nconst preservedData = $node[\"Set\"].json;\n\n// Get job title and description from the Set Job Title node\nconst jobData = $node[\"Set Job Title and Job Description\"].json;\n\nconsole.log('=== CODE NODE EXECUTION ===');\nconsole.log('Has preservedBinary:', !!preservedData?.preservedBinary);\nconsole.log('Original file name:', preservedData?.originalFileName);\nconsole.log('AI Output keys:', Object.keys(aiOutput || {}));\nconsole.log('Job Title:', jobData?.job_title);\n\n// Parse the AI response\nlet aiResult = {};\nif (aiOutput?.output) {\n  try {\n    aiResult = JSON.parse(aiOutput.output);\n    console.log('Parsed AI output successfully');\n  } catch (e) {\n    console.error('Failed to parse AI output:', e.message);\n    aiResult = {};\n  }\n} else {\n  // Try to parse the whole thing\n  try {\n    aiResult = typeof aiOutput === 'string' ? JSON.parse(aiOutput) : aiOutput;\n  } catch (e) {\n    aiResult = {};\n  }\n}\n\n// Extract AI results\nconst candidateName = aiResult.candidate_name || 'Unknown';\nconst skills = aiResult.skills || [];\nconst score = aiResult.match_score || 0;\nconst strengths = aiResult.strengths || [];\nconst missingSkills = aiResult.missing_skills || [];\nconst recommendation = aiResult.recommendation || (score >= 70 ? 'Proceed' : 'Reject');\nconst reason = aiResult.reason || 'No reason provided';\nconst passed = score >= 70;\n\n// ⚠️ Get binary from Set node (NOT from AI Agent)\nconst binaryData = preservedData?.preservedBinary || null;\nconst fileName = preservedData?.originalFileName || 'resume.pdf';\nconst emailAddress = preservedData?.applicantEmail || 'unknown@email.com';\nconst emailName = preservedData?.applicantName || 'Unknown Applicant';\n\n// Get job title and description\nconst jobTitle = jobData?.job_title || 'Not specified';\nconst jobDescription = jobData?.job_description || 'Not specified';\n\nconsole.log('=== FINAL OUTPUT ===');\nconsole.log('Candidate:', candidateName);\nconsole.log('Score:', score);\nconsole.log('Passed:', passed);\nconsole.log('Has Binary:', !!binaryData);\nconsole.log('File Name:', fileName);\nconsole.log('Job Title:', jobTitle);\n\n// Return combined data\nreturn [{\n  // AI Analysis results\n  candidate_name: candidateName,\n  skills: skills,\n  match_score: score,\n  strengths: strengths,\n  missing_skills: missingSkills,\n  recommendation: recommendation,\n  reason: reason,\n  \n  // Pass/Fail\n  passed: passed,\n  \n  // ⚠️ Binary from Set node (RECONSTRUCTED)\n  preservedBinary: binaryData,\n  originalFileName: fileName,\n  \n  // Applicant info from Set node\n  applicantEmail: emailAddress,\n  applicantName: emailName,\n  \n  // Job info from Set Job Title node\n  job_title: jobTitle,\n  job_description: jobDescription,\n  \n  // Metadata\n  analyzedAt: new Date().toISOString(),\n  \n  // Debug info\n  _debug: {\n    binarySource: preservedData?.preservedBinary ? 'Set node' : 'NOT FOUND',\n    hasAIOutput: !!aiOutput?.output,\n    setNodeKeys: Object.keys(preservedData || {}),\n    jobTitleSource: jobData?.job_title ? 'Set Job Title node' : 'NOT FOUND'\n  }\n}];"
      },
